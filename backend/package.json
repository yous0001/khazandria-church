{
    "name": "khazandria-church-backend",
    "version": "1.2.0",
    "description": "Backend for Khazandria Church Activities Management System",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc && node -e \"const fs=require('fs');if(fs.existsSync('src/assets'))fs.cpSync('src/assets','dist/assets',{recursive:true})\"",
        "start": "node dist/server.js",
        "seed": "ts-node src/scripts/seed.ts",
        "migrate:session-bonus": "ts-node src/scripts/migrateSessionGradesToBonusOnly.ts"
    },
    "keywords": [
        "church",
        "activities",
        "management"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cloudinary": "^2.8.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "multer": "^2.0.2",
        "pdfkit": "^0.18.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.10.6",
        "@types/pdfkit": "^0.17.6",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}
